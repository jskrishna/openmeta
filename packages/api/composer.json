{
    "name": "openmeta/api",
    "version": "0.7.0-alpha",
    "description": "OpenMeta REST API \u2014 routes, controllers, resources, authentication, authorization.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "openmeta/core": "*",
        "openmeta/support": "*",
        "openmeta/validation": "*",
        "openmeta/security": "*",
        "openmeta/database": "*",
        "openmeta/fields": "*"
    },
    "autoload": {
        "psr-4": {
            "OpenMeta\\Api\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenMeta\\Api\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
