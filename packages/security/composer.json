{
    "name": "openmeta/security",
    "version": "0.4.0-alpha",
    "description": "OpenMeta security \u2014 permissions, capabilities, nonces, sanitization, and escaping. No UI.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "openmeta/core": "*",
        "openmeta/support": "*"
    },
    "autoload": {
        "psr-4": {
            "OpenMeta\\Security\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenMeta\\Security\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
