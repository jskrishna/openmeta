{
    "name": "openmeta/core",
    "version": "0.1.0-alpha",
    "description": "OpenMeta core runtime \u2014 application lifecycle, container, providers, config, events, and kernel.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3"
    },
    "autoload": {
        "psr-4": {
            "OpenMeta\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenMeta\\Core\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
