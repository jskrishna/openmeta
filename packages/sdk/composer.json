{
    "name": "openmeta/sdk",
    "version": "0.13.0-beta",
    "description": "OpenMeta Extension SDK — manifest, discovery, dependency resolution, compatibility, lifecycle, and resource registration for third-party extensions.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "openmeta/core": "*",
        "openmeta/support": "*",
        "openmeta/validation": "*",
        "openmeta/security": "*",
        "openmeta/database": "*",
        "openmeta/fields": "*",
        "openmeta/rest": "*"
    },
    "autoload": {
        "psr-4": {
            "OpenMeta\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenMeta\\Sdk\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
