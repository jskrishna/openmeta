{
    "name": "openmeta/ui",
    "version": "0.8.0-alpha",
    "description": "OpenMeta shared UI primitives and components for admin and builder.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "openmeta/core": "*",
        "openmeta/security": "*"
