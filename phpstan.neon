parameters:
    level: 5
    phpVersion: 80300
    paths:
        - packages/core/src
        - packages/core/tests
        - packages/support/src
        - packages/support/tests
        - packages/validation/src
        - packages/validation/tests
        - packages/security/src
        - packages/security/tests
        - packages/database/src
        - packages/database/tests
        - packages/fields/src
        - packages/fields/tests
        - packages/rest/src
        - packages/rest/tests
        - packages/api/src
        - packages/api/tests
        - packages/wordpress/src
        - packages/wordpress/tests
        - packages/ui/src
        - packages/ui/tests
        - packages/admin/src
        - packages/admin/tests
        - packages/builder/src
        - packages/builder/tests
        - packages/sdk/src
        - packages/sdk/tests
    excludePaths:
        - */vendor/*
        - */node_modules/*
        - packages/core/tests/Fixtures/*
        - packages/core/tests/Unit/bootstrap.php
        - packages/core/tests/Unit/application.php
        - packages/core/tests/Unit/configuration.php
        - packages/core/tests/Unit/container.php
        - packages/core/tests/Unit/kernel.php
        - packages/core/tests/Unit/service-providers.php
        - packages/core/tests/smoke.php
        - packages/core/config/*
        - packages/database/tests/Fixtures/*
        - packages/rest/tests/Fixtures/*

    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
