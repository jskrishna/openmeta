            <directory suffix="Test.php">packages/wordpress/tests/Performance</directory>
            <directory suffix="Test.php">packages/wordpress/tests/Security</directory>
        </testsuite>
        <testsuite name="phase12-unit">
            <directory suffix="Test.php">packages/*/tests/Unit</directory>
        </testsuite>
        <testsuite name="phase12-integration">
            <directory suffix="Test.php">packages/*/tests/Integration</directory>
        </testsuite>
        <testsuite name="phase12-wordpress">
            <directory suffix="Test.php">packages/*/tests/WordPress</directory>
        </testsuite>
        <testsuite name="phase12-performance">
            <directory suffix="Test.php">packages/*/tests/Performance</directory>
        </testsuite>
        <testsuite name="phase12-security">
            <directory suffix="Test.php">packages/*/tests/Security</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>packages/core/src</directory>
            <directory>packages/support/src</directory>
            <directory>packages/validation/src</directory>
            <directory>packages/security/src</directory>
            <directory>packages/database/src</directory>
            <directory>packages/fields/src</directory>
            <directory>packages/rest/src</directory>
            <directory>packages/api/src</directory>
            <directory>packages/ui/src</directory>
            <directory>packages/admin/src</directory>
            <directory>packages/builder/src</directory>
