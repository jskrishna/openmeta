<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         cacheDirectory=".phpunit.cache"
         executionOrder="depends,defects"
         requireCoverageMetadata="false"
         beStrictAboutOutputDuringTests="true"
         failOnRisky="true"
         failOnWarning="true"
         defaultTestSuite="ci">
    <testsuites>
        <testsuite name="ci">
            <directory suffix="Test.php">packages/core/tests</directory>
            <exclude>packages/core/tests/Fixtures</exclude>
            <exclude>packages/core/tests/CoreTestCase.php</exclude>
            <directory suffix="Test.php">packages/support/tests</directory>
            <exclude>packages/support/tests/SupportTestCase.php</exclude>
            <directory suffix="Test.php">packages/validation/tests</directory>
            <exclude>packages/validation/tests/ValidationTestCase.php</exclude>
            <directory suffix="Test.php">packages/security/tests</directory>
            <exclude>packages/security/tests/SecurityTestCase.php</exclude>
            <directory suffix="Test.php">packages/database/tests</directory>
            <exclude>packages/database/tests/DatabaseTestCase.php</exclude>
            <exclude>packages/database/tests/Fixtures</exclude>
            <directory suffix="Test.php">packages/fields/tests</directory>
            <exclude>packages/fields/tests/FieldsTestCase.php</exclude>
            <directory suffix="Test.php">packages/rest/tests</directory>
            <exclude>packages/rest/tests/RestTestCase.php</exclude>
            <exclude>packages/rest/tests/Fixtures</exclude>
            <directory suffix="Test.php">packages/api/tests</directory>
            <exclude>packages/api/tests/ApiTestCase.php</exclude>
            <directory suffix="Test.php">packages/ui/tests</directory>
            <directory suffix="Test.php">packages/admin/tests</directory>
            <exclude>packages/admin/tests/AdminTestCase.php</exclude>
            <directory suffix="Test.php">packages/builder/tests</directory>
            <exclude>packages/builder/tests/BuilderTestCase.php</exclude>
            <directory suffix="Test.php">packages/wordpress/tests</directory>
            <exclude>packages/wordpress/tests/WordpressTestCase.php</exclude>
            <directory suffix="Test.php">tests/Phase12</directory>
        </testsuite>
        <testsuite name="core">
            <directory suffix="Test.php">packages/core/tests</directory>
            <exclude>packages/core/tests/Fixtures</exclude>
            <exclude>packages/core/tests/CoreTestCase.php</exclude>
        </testsuite>
        <testsuite name="support">
            <directory suffix="Test.php">packages/support/tests</directory>
            <exclude>packages/support/tests/SupportTestCase.php</exclude>
        </testsuite>
        <testsuite name="validation">
            <directory suffix="Test.php">packages/validation/tests</directory>
            <exclude>packages/validation/tests/ValidationTestCase.php</exclude>
        </testsuite>
        <testsuite name="security">
            <directory suffix="Test.php">packages/security/tests</directory>
            <exclude>packages/security/tests/SecurityTestCase.php</exclude>
        </testsuite>
        <testsuite name="database">
            <directory suffix="Test.php">packages/database/tests</directory>
            <exclude>packages/database/tests/DatabaseTestCase.php</exclude>
            <exclude>packages/database/tests/Fixtures</exclude>
        </testsuite>
        <testsuite name="fields">
            <directory suffix="Test.php">packages/fields/tests</directory>
            <exclude>packages/fields/tests/FieldsTestCase.php</exclude>
        </testsuite>
        <testsuite name="rest">
            <directory suffix="Test.php">packages/rest/tests</directory>
            <exclude>packages/rest/tests/RestTestCase.php</exclude>
            <exclude>packages/rest/tests/Fixtures</exclude>
        </testsuite>
        <testsuite name="api">
            <directory suffix="Test.php">packages/api/tests</directory>
            <exclude>packages/api/tests/ApiTestCase.php</exclude>
        </testsuite>
        <testsuite name="ui">
            <directory suffix="Test.php">packages/ui/tests</directory>
        </testsuite>
        <testsuite name="admin">
            <directory suffix="Test.php">packages/admin/tests</directory>
            <exclude>packages/admin/tests/AdminTestCase.php</exclude>
        </testsuite>
        <testsuite name="builder">
            <directory suffix="Test.php">packages/builder/tests</directory>
            <exclude>packages/builder/tests/BuilderTestCase.php</exclude>
        </testsuite>
        <testsuite name="wordpress">
            <directory suffix="Test.php">packages/wordpress/tests</directory>
            <exclude>packages/wordpress/tests/WordpressTestCase.php</exclude>
        </testsuite>
        <testsuite name="phase12">
            <directory suffix="Test.php">tests/Phase12</directory>
            <directory suffix="Test.php">packages/core/tests/Unit</directory>
            <directory suffix="Test.php">packages/core/tests/Integration</directory>
            <directory suffix="Test.php">packages/core/tests/WordPress</directory>
            <directory suffix="Test.php">packages/core/tests/Performance</directory>
            <directory suffix="Test.php">packages/core/tests/Security</directory>
            <directory suffix="Test.php">packages/support/tests/Unit</directory>
            <directory suffix="Test.php">packages/support/tests/Integration</directory>
            <directory suffix="Test.php">packages/support/tests/WordPress</directory>
