# Automatically normalize line endings on checkout/commit.
* text=auto eol=lf

# Declare files that always use LF.
*.php text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.svg text eol=lf
*.sh text eol=lf

# Windows scripts may keep CRLF when needed.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.gz binary
*.phar binary

# Export ignore (optional packaging hygiene)
.gitattributes export-ignore
.gitignore export-ignore
.github export-ignore
.editorconfig export-ignore
