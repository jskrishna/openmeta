# EditorConfig

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4

[*.{yml,yaml,json,md,mdx}]
indent_style = space
indent_size = 2

[*.{js,jsx,ts,tsx,css,scss}]
indent_style = tab
indent_size = 4

[*.{php,phtml}]
indent_style = tab
indent_size = 4

[composer.json]
indent_style = space
indent_size = 4

[package.json]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
