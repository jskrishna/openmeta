{
    "name": "openmeta/openmeta",
    "description": "Modern open-source content modeling framework for WordPress.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "OpenMeta Contributors",
            "homepage": "https://github.com/jskrishna/openmeta"
        }
    ],
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "scripts": {
        "phpcs": "phpcs",
        "phpstan": "phpstan analyse --memory-limit=1G",
        "phpunit": "phpunit --configuration phpunit.xml",
        "ci": [
            "@phpstan",
            "@phpcs",
            "@phpunit"
        ],
        "qa": [
            "@ci",
            "@bc:check"
        ],
        "bench": "php quality/benchmarks/run.php",
        "bc:check": "php quality/tools/bc-check.php",
        "bc:update": "php quality/tools/bc-check.php --update",
        "coverage": "phpunit --configuration phpunit.xml --coverage-clover quality/coverage/clover.xml --coverage-text",
        "coverage:check": "php quality/tools/coverage-check.php quality/coverage/clover.xml 70",
        "release:validate": "php quality/tools/release-validate.php",
        "workspace": [
            "@ci"
        ],
        "test": [
            "@test:core",
            "@test:support",
            "@test:validation",
            "@test:security",
            "@test:database",
            "@test:fields",
            "@test:rest",
            "@test:api",
            "@test:wordpress",
            "@test:ui",
            "@test:admin",
            "@test:builder",
            "@test:extensions",
            "@test:graphql",
            "@test:cli",
            "@test:framework",
            "@test:generator"
        ],
        "test:core": [
            "phpunit --configuration phpunit.xml --testsuite core",
            "php packages/core/tests/smoke.php"
        ],
        "test:support": [
            "phpunit --configuration phpunit.xml --testsuite support"
        ],
        "test:validation": [
            "phpunit --configuration phpunit.xml --testsuite validation"
        ],
        "test:security": [
            "phpunit --configuration phpunit.xml --testsuite security"
        ],
        "test:database": [
            "phpunit --configuration phpunit.xml --testsuite database"
        ],
        "test:fields": [
            "phpunit --configuration phpunit.xml --testsuite fields"
        ],
        "test:rest": [
            "phpunit --configuration phpunit.xml --testsuite rest"
        ],
        "test:api": [
            "phpunit --configuration phpunit.xml --testsuite api"
        ],
        "test:wordpress": [
            "phpunit --configuration phpunit.xml --testsuite wordpress"
        ],
        "test:ui": [
            "phpunit --configuration phpunit.xml --testsuite ui"
        ],
        "test:admin": [
            "phpunit --configuration phpunit.xml --testsuite admin"
        ],
        "test:builder": [
            "phpunit --configuration phpunit.xml --testsuite builder"
        ],
        "test:extensions": [
            "phpunit --configuration phpunit.xml --testsuite extensions"
        ],
        "test:graphql": [
            "phpunit --configuration phpunit.xml --testsuite graphql"
        ],
        "test:cli": [
            "phpunit --configuration phpunit.xml --testsuite cli"
        ],
        "test:framework": [
            "phpunit --configuration phpunit.xml --testsuite framework"
        ],
        "test:generator": [
            "phpunit --configuration phpunit.xml --testsuite generator"
        ],
        "test:e2e": [
            "phpunit --configuration phpunit.xml --testsuite e2e"
        ]
    },
    "autoload": {
        "psr-4": {
            "OpenMeta\\Core\\": "packages/core/src/",
            "OpenMeta\\Support\\": "packages/support/src/",
            "OpenMeta\\Validation\\": "packages/validation/src/",
            "OpenMeta\\Security\\": "packages/security/src/",
            "OpenMeta\\Database\\": "packages/database/src/",
            "OpenMeta\\Fields\\": "packages/fields/src/",
            "OpenMeta\\Rest\\": "packages/rest/src/",
            "OpenMeta\\Api\\": "packages/api/src/",
            "OpenMeta\\Wordpress\\": "packages/wordpress/src/",
            "OpenMeta\\Ui\\": "packages/ui/src/",
            "OpenMeta\\Admin\\": "packages/admin/src/",
            "OpenMeta\\Builder\\": "packages/builder/src/",
            "OpenMeta\\Extensions\\": "packages/extensions/src/",
            "OpenMeta\\GraphQL\\": "packages/graphql/src/",
            "OpenMeta\\Cli\\": "packages/cli/src/",
            "OpenMeta\\Framework\\": "packages/framework/src/",
            "OpenMeta\\Generator\\": "packages/generator/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenMeta\\Core\\Tests\\": "packages/core/tests/",
            "OpenMeta\\Support\\Tests\\": "packages/support/tests/",
            "OpenMeta\\Validation\\Tests\\": "packages/validation/tests/",
            "OpenMeta\\Security\\Tests\\": "packages/security/tests/",
            "OpenMeta\\Database\\Tests\\": "packages/database/tests/",
            "OpenMeta\\Fields\\Tests\\": "packages/fields/tests/",
            "OpenMeta\\Rest\\Tests\\": "packages/rest/tests/",
            "OpenMeta\\Api\\Tests\\": "packages/api/tests/",
            "OpenMeta\\Wordpress\\Tests\\": "packages/wordpress/tests/",
            "OpenMeta\\Ui\\Tests\\": "packages/ui/tests/",
            "OpenMeta\\Admin\\Tests\\": "packages/admin/tests/",
            "OpenMeta\\Builder\\Tests\\": "packages/builder/tests/",
            "OpenMeta\\Extensions\\Tests\\": "packages/extensions/tests/",
            "OpenMeta\\GraphQL\\Tests\\": "packages/graphql/tests/",
            "OpenMeta\\Cli\\Tests\\": "packages/cli/tests/",
            "OpenMeta\\Framework\\Tests\\": "packages/framework/tests/",
            "OpenMeta\\Generator\\Tests\\": "packages/generator/tests/",
            "OpenMeta\\Tests\\": "tests/"
        },
        "exclude-from-classmap": [
            "/packages/core/tests/",
            "/packages/support/tests/",
            "/packages/validation/tests/",
            "/packages/security/tests/",
            "/packages/database/tests/",
            "/packages/fields/tests/",
            "/packages/rest/tests/",
            "/packages/api/tests/",
            "/packages/wordpress/tests/",
            "/packages/ui/tests/",
            "/packages/admin/tests/",
            "/packages/builder/tests/",
            "/packages/extensions/tests/",
            "/packages/graphql/tests/",
            "/packages/cli/tests/",
            "/tests/",
            "/packages/framework/tests/",
            "/packages/generator/tests/"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
