{
  "name": "openmeta/openmeta",
  "description": "Modern open-source content modeling framework for WordPress.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "OpenMeta Contributors",
      "homepage": "https://github.com/jskrishna/openmeta"
    }
  ],
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^11.0",
    "squizlabs/php_codesniffer": "^3.10"
  },
  "scripts": {
    "phpcs": "phpcs",
    "phpstan": "phpstan analyse --memory-limit=1G",
    "phpunit": "phpunit --configuration phpunit.xml",
    "ci": [
      "@phpstan",
      "@phpcs",
      "@phpunit"
    ],
    "workspace": [
      "@ci"
    ],
    "test": [
      "@test:core"
    ],
    "test:core": [
      "phpunit --configuration phpunit.xml --testsuite core",
      "php packages/core/tests/smoke.php"
    ]
  },
  "autoload": {
    "psr-4": {
      "OpenMeta\\Core\\": "packages/core/src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OpenMeta\\Core\\Tests\\": "packages/core/tests/",
      "OpenMeta\\Tests\\": "tests/"
    },
    "exclude-from-classmap": [
      "/packages/core/tests/",
      "/tests/"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {}
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
